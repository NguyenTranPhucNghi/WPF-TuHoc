<Window x:Class="WBF_Tuan_1.ChiTietGiaoDich"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WBF_Tuan_1"
        mc:Ignorable="d"
        Title="ChiTietGiaoDich" Height="500" Width="800">
	<StackPanel>
		<StackPanel  HorizontalAlignment="Stretch">
			<Label Content="Chi tiết giao dịch" 
            FontSize="18" 
            Foreground="Black" 
            BorderThickness="0" 
            Background="Transparent" 
            HorizontalAlignment="Left" Margin="20,10,0,10" VerticalAlignment="Top"/>
		</StackPanel>

		<StackPanel  HorizontalAlignment="Stretch">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Column="0">
					<TextBlock Text="Khách hàng" 
					FontSize="14"
					Foreground="Gray"
					HorizontalAlignment="Left"
					Margin="25,0,0,0"/>

					<TextBlock Text="👤 Nguyễn Thị Mai"
					FontSize="16"
					Foreground="Black"
					HorizontalAlignment="Left"
					Margin="25,0,0,0"/>
				</StackPanel>

				<StackPanel Grid.Column="1">
					<TextBlock Text="Nhà tiên tri" 
				FontSize="14"
				Foreground="Gray"
				HorizontalAlignment="Left"
				Margin="25,0,0,0"/>

					<TextBlock Text="👤 Minh Tuệ" 
				FontSize="16"
				Foreground="Black"
				HorizontalAlignment="Left"
				Margin="25,0,0,0"/>
				</StackPanel>
			</Grid>
		</StackPanel>

		<StackPanel  HorizontalAlignment="Stretch">
			<TextBlock Text="Thời điểm giao dịch" 
			FontSize="14"
			Foreground="Gray"
			HorizontalAlignment="Left"
			Margin="25,8,0,0"/>

			<TextBlock Text="📅 21:23:00 21/02/1991" 
			FontSize="16"
			Foreground="Black"
			HorizontalAlignment="Left"
			Margin="25,0,0,0"/>
		</StackPanel>

		<StackPanel 
		HorizontalAlignment="Stretch" 
		Height="1" 
		Background="Gray"
		Margin="25,8,25,0">
		</StackPanel>

		<StackPanel  HorizontalAlignment="Stretch">
			<TextBlock Text="Thông tin thanh toán" 
			FontSize="14"
			Foreground="Black"
			HorizontalAlignment="Left"
			Margin="25,10,0,0"/>

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>

				<StackPanel Grid.Column="0">
					<TextBlock Text="Mã giao dịch" 
					FontSize="12"
					Foreground="Gray"
					HorizontalAlignment="Left"
					Margin="25,8,10,2"/>

					<TextBlock Text="Dịch vụ" 
					FontSize="12"
					Foreground="Gray"
					HorizontalAlignment="Left"
					Margin="25,2,0,2"/>

					<TextBlock Text="Trạng thái" 
					FontSize="12"
					Foreground="Gray"
					HorizontalAlignment="Left"
					Margin="25,2,0,2"/>

					<TextBlock Text="Giá tiền" 
					FontSize="12"
					Foreground="Gray"
					HorizontalAlignment="Left"
					Margin="25,2,0,0"/>
				</StackPanel>

				<StackPanel Grid.Column="1">
					<TextBlock Text="#1234...." 
					FontSize="14"
					Foreground="Black"
					HorizontalAlignment="Right"
					Margin="25,6,10,0"/>

					<TextBlock Text="Tư vấn tổng quan vận mệnh 2024" 
					FontSize="14"
					Foreground="Black"
					HorizontalAlignment="Right"
					Margin="25,2,10,0"/>

					<TextBlock Text="Thành công" 
					FontSize="14"
					Foreground="Black"
					HorizontalAlignment="Right"
					Margin="25,2,10,0"/>

					<TextBlock Text="299.000 VNĐ" 
					FontSize="14"
					Foreground="Black"
					HorizontalAlignment="Right"
					Margin="25,2,10,0"/>	
				</StackPanel>
			</Grid>
		</StackPanel>

		<Border BorderBrush="Gray"
        BorderThickness="1"
        CornerRadius="5"
        Padding="10"
        Margin="20,40,20,0">

			<StackPanel>
				<TextBlock 
				Text="📱VNPay"
				FontSize="16"
				Margin="0,0,0,10"/>

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0">
						<TextBlock Text="Tổng tiền" 
						FontSize="12"
						Foreground="Gray"
						HorizontalAlignment="Left"
						Margin="25,0,0,0"/>

						<TextBlock Text="299.000 VNĐ" 
						FontSize="14"
						Foreground="Black"
						HorizontalAlignment="Left"
						Margin="25,0,0,0"/>
					</StackPanel>

					<StackPanel Grid.Column="1">
						<TextBlock Text="Phí nền tảng (10%)" 
						FontSize="12"
						Foreground="Gray"
						HorizontalAlignment="Left"
						Margin="25,0,0,0"/>

						<TextBlock Text="29.900 VNĐ" 
						FontSize="14"
						Foreground="Black"
						HorizontalAlignment="Left"
						Margin="25,0,0,0"/>
					</StackPanel>

					<StackPanel Grid.Column="2">
						<TextBlock Text="Nhà tiên tri nhận được" 
						FontSize="12"
						Foreground="Gray"
						HorizontalAlignment="Left"
						Margin="25,0,0,0"/>

						<TextBlock Text="261.100 VNĐ" 
						FontSize="14"
						Foreground="LightGreen"
						HorizontalAlignment="Left"
						Margin="25,0,0,0"/>
					</StackPanel>
				</Grid>
			</StackPanel>

		</Border>

	</StackPanel>
</Window>
