<Page x:Class="WBF_Tuan_1.LogIn"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WBF_Tuan_1"
        mc:Ignorable="d"
        Title="LogIn" Height="450" Width="800">
    <Grid>
		<Label Content="Log In" HorizontalAlignment="Center" Margin="0,62,0,0" VerticalAlignment="Top" FontSize="35" FontWeight="Bold" Foreground="SkyBlue" RenderTransformOrigin="0.25,-0.341"/>

		<TextBox HorizontalAlignment="Center"
 Foreground="Gray"
 FontSize="13"
 Margin="0,124,0,0"
 Text=" Email Address/Username"
 Width="244"
 Height="36"
 VerticalAlignment="Top"
 VerticalContentAlignment="Center"
 BorderThickness="0">
			<TextBox.Template>
				<ControlTemplate TargetType="TextBox">
					<Border CornerRadius="5"
            Background="White"
            BorderBrush="LightGray"
            BorderThickness="1">
						<ScrollViewer x:Name="PART_ContentHost"/>
					</Border>
				</ControlTemplate>
			</TextBox.Template>
		</TextBox>

		<TextBox HorizontalAlignment="Center"
 Foreground="Gray"
 FontSize="13"
 Margin="0,165,0,0"
 Text=" Password"
 Width="244"
 Height="39"
 VerticalAlignment="Top"
 VerticalContentAlignment="Center"
 BorderThickness="0">
			<TextBox.Template>
				<ControlTemplate TargetType="TextBox">
					<Border CornerRadius="5"
            Background="White"
            BorderBrush="LightGray"
            BorderThickness="1">
						<ScrollViewer x:Name="PART_ContentHost"/>
					</Border>
				</ControlTemplate>
			</TextBox.Template>
		</TextBox>

		<CheckBox Content="Remember me" Foreground="DarkGray" HorizontalAlignment="Left" Margin="278,225,0,0" VerticalAlignment="Top" Width="104" RenderTransformOrigin="0.498,2.275"/>

		<Button Content="Log In"
FontSize="15"
Foreground="White"
HorizontalAlignment="Center"
Margin="0,245,0,0"
VerticalAlignment="Top"
Height="38"
Width="244">
			<Button.Template>
				<ControlTemplate TargetType="Button">
					<Border Background="Blue"
            CornerRadius="8">
						<ContentPresenter
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>
					</Border>
				</ControlTemplate>
			</Button.Template>
		</Button>

		<Label Content="  Or" Foreground="DarkGray" HorizontalAlignment="Center" Margin="0,283,0,0" VerticalAlignment="Top" Height="25" Width="40"/>

		<Button Content="Sign in with Google" FontSize="12" FontWeight="Bold" Background="Transparent" HorizontalAlignment="Center" Margin="0,308,0,0" VerticalAlignment="Top" Height="32" Width="244"/>
		<Button Content="Forgot your password ?" Foreground="DarkGray" BorderThickness="0" Background="Transparent" HorizontalAlignment="Center" Margin="0,345,0,0" VerticalAlignment="Top"/>

		<Label Content="Create account" Foreground="DarkGray" FontSize="14" FontWeight="DemiBold" HorizontalAlignment="Left" Margin="318,377,0,0" VerticalAlignment="Top" Width="129" Height="27"/>
		<Button Content="Sign up" Click="btnSignUp_Click" FontSize="14" FontWeight="Bold" Foreground="Blue" BorderThickness="0" Background="Transparent" HorizontalAlignment="Left" Margin="421,381,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.83,-0.981"/>
	</Grid>
</Page>
