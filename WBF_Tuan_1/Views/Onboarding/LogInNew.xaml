<Page x:Class="WBF_Tuan_1.Views.Onboarding.LogInNew"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WBF_Tuan_1"
        mc:Ignorable="d"
        Title="LogInNew" Height="450" Width="800">
	<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
		<Label Content="Log In" HorizontalAlignment="Center" FontSize="35" FontWeight="Bold" Foreground="SkyBlue" RenderTransformOrigin="0.25,-0.341"/>

		<TextBox
        Text=" EmailAddress/Username"
        Background="Transparent"
        BorderThickness="0"
        Margin="0,0,0,-5"
        FontStyle="Italic"
        Foreground="Gray"
        ></TextBox>

		<TextBox HorizontalAlignment="Center"
         Foreground="Gray"
         FontSize="13"
         Width="244"
         Height="36"
         x:Name="txtEmailAdress"
         Margin="0,10,0,0"
         VerticalAlignment="Top"
         VerticalContentAlignment="Center"
         BorderThickness="0">
			<TextBox.Template>
				<ControlTemplate TargetType="TextBox">
					<Border CornerRadius="5"
                    Background="White"
                    BorderBrush="LightGray"
                    BorderThickness="1">
						<ScrollViewer x:Name="PART_ContentHost"/>
					</Border>
				</ControlTemplate>
			</TextBox.Template>
		</TextBox>

		<TextBox
        Text=" Password"
        Background="Transparent"
        BorderThickness="0"
        Margin="0,0,0,-10"
        FontStyle="Italic"
        Foreground="Gray"
        ></TextBox>

		<TextBox HorizontalAlignment="Center"
        Foreground="Gray"
        FontSize="13"
        Margin="0,10,0,0"
        Width="244"
        Height="39"
        x:Name="txtPassword"
        VerticalAlignment="Top"
        VerticalContentAlignment="Center"
        BorderThickness="0">
			<TextBox.Template>
				<ControlTemplate TargetType="TextBox">
					<Border CornerRadius="5"
            Background="White"
            BorderBrush="LightGray"
            BorderThickness="1">
						<ScrollViewer x:Name="PART_ContentHost"/>
					</Border>
				</ControlTemplate>
			</TextBox.Template>
		</TextBox>

		<CheckBox Content="Remember me" Foreground="DarkGray" HorizontalAlignment="Left" Margin="5,20,0,0" VerticalAlignment="Top" Width="105" RenderTransformOrigin="0.498,2.275"/>

		<Button Content="Log In"
        FontSize="15"
        FontWeight="Bold"
        Foreground="White"
        HorizontalAlignment="Center"
        Margin="0,8,0,0"
        VerticalAlignment="Top"
        Height="38"
        Width="244">
			<Button.Template>
				<ControlTemplate TargetType="Button">
					<Border Background="Blue"
            CornerRadius="8">
						<ContentPresenter
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>
					</Border>
				</ControlTemplate>
			</Button.Template>
		</Button>

		<Label Content="  Or" Foreground="DarkGray" HorizontalAlignment="Center" Margin="0,3,0,0" VerticalAlignment="Top" Height="25" Width="40"/>

		<Button Content="Sign in by Google"
        FontSize="15"
        FontWeight="Bold"
        Foreground="Black"
        HorizontalAlignment="Center"
        Margin="0,0,0,0"
        VerticalAlignment="Top"
        Height="38"
        Width="244">
			<Button.Template>
				<ControlTemplate TargetType="Button">
					<Border 
                    Background="White"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="8">
						<ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
					</Border>
				</ControlTemplate>
			</Button.Template>
		</Button>

		<StackPanel  HorizontalAlignment="Stretch">
			<Button Content="Forgot your password ?" Foreground="DarkGray" BorderThickness="0" Background="Transparent" HorizontalAlignment="Left" Margin="0,5,0,0" VerticalAlignment="Top"/>
		</StackPanel>
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Label Grid.Column="0"
           Content="Create account"
           Foreground="DarkGray"
           FontSize="14"
           FontWeight="DemiBold"
           HorizontalAlignment="Left"
           VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="-5,0,0,0" />

			<Button Grid.Column="1"
            Content="Sign up"
            Click="btnSignUp_Click"
            FontSize="14"
            FontWeight="Bold"
            Foreground="Blue"
            BorderThickness="0"
            Background="Transparent"
            HorizontalAlignment="Left"
            VerticalAlignment="Center" RenderTransformOrigin="-0.301,0.459" Margin="-20,0,0,0" Height="25" />
		</Grid>

	</StackPanel>
</Page>
