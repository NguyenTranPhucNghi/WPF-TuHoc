<Window x:Class="WBF_Tuan_1.Signup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WBF_Tuan_1"
        mc:Ignorable="d"
        Title="Signup" Height="450" Width="800">
    <Grid>
        <Label Content="Sign up" HorizontalAlignment="Center" Margin="0,62,0,0" VerticalAlignment="Top" FontSize="35" FontWeight="Bold" Foreground="Black" RenderTransformOrigin="0.25,-0.341"/>

        <TextBox HorizontalAlignment="Center"
        Foreground="Gray"
        FontSize="13"
        Margin="0,124,0,0"
        Text=" Email Address"
        Width="244"
        Height="36"
        VerticalAlignment="Top"
        VerticalContentAlignment="Center"
        BorderThickness="0">
            <TextBox.Template>
                <ControlTemplate TargetType="TextBox">
                    <Border CornerRadius="5"
            Background="White"
            BorderBrush="LightGray"
            BorderThickness="1">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </TextBox.Template>
        </TextBox>

        <TextBox HorizontalAlignment="Center"
        Foreground="Gray"
        FontSize="13"
        Margin="0,165,0,0"
        Text=" Password"
        Width="244"
        Height="39"
        VerticalAlignment="Top"
        VerticalContentAlignment="Center"
        BorderThickness="0">
            <TextBox.Template>
                <ControlTemplate TargetType="TextBox">
                    <Border CornerRadius="5"
            Background="White"
            BorderBrush="LightGray"
            BorderThickness="1">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </TextBox.Template>
        </TextBox>

        <Button Content="Sign Up"
        FontWeight="Bold"
        FontSize="15"
        Foreground="White"
        HorizontalAlignment="Left"
        Margin="278,299,0,0"
        VerticalAlignment="Top"
        Height="38"
        Width="239">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="DeepSkyBlue"
            CornerRadius="8">
                        <ContentPresenter
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <CheckBox Content="Remember me" Foreground="DarkGray" HorizontalAlignment="Left" Margin="278,342,0,0" VerticalAlignment="Top" Width="104" RenderTransformOrigin="0.498,2.275"/>


        <Label Content="Have an account ?" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" Margin="300,357,0,0" VerticalAlignment="Top" Width="129" Height="27"/>
        <Button Content="Log In" FontSize="14" FontWeight="Bold" Foreground="Blue" BorderThickness="0" Background="Transparent" HorizontalAlignment="Left" Margin="429,360,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.83,-0.981"/>

        <TextBox HorizontalAlignment="Center"
            Foreground="Gray"
            FontSize="13"
            Margin="0,209,0,0"
            Text=" Phone number"
            Width="244"
            Height="39"
            VerticalAlignment="Top"
            VerticalContentAlignment="Center"
            BorderThickness="0" RenderTransformOrigin="0.511,1.428">
            <TextBox.Template>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border CornerRadius="5"
                        Background="White"
                        BorderBrush="LightGray"
                        BorderThickness="1">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </TextBox.Template>
        </TextBox>
		<TextBox HorizontalAlignment="Center"
            Foreground="Gray"
            FontSize="13"
            Margin="0,253,0,0"
            Text=" Username"
            Width="244"
            Height="39"
            VerticalAlignment="Top"
            VerticalContentAlignment="Center"
            BorderThickness="0" RenderTransformOrigin="0.511,1.428">
			<TextBox.Template>
				<ControlTemplate TargetType="{x:Type TextBox}">
					<Border CornerRadius="5"
                        Background="White"
                        BorderBrush="LightGray"
                        BorderThickness="1">
						<ScrollViewer x:Name="PART_ContentHost"/>
					</Border>
				</ControlTemplate>
			</TextBox.Template>
		</TextBox>

	</Grid>
</Window>
